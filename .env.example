# Copy to .env.local and fill in. Never commit your real values.

# --- xBloom account (optional env; can also be added in Settings) ---
XBLOOM_EMAIL=
XBLOOM_PASSWORD=

# --- Vercel AI Gateway (optional env; can also be added in Settings) ---
# https://vercel.com/ai-gateway — make sure it has credits.
AI_GATEWAY_API_KEY=

# --- App auth (Better Auth, email/password) ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Set this to your deployed origin in production, e.g. https://pourpilot.example.com
BETTER_AUTH_URL=http://localhost:3000
# First account can always be created. Set true to keep signups open after that.
# ALLOW_SIGNUPS=false

# Optional: override the model. Must support vision + web search.
# AI_MODEL=openai/gpt-4o

# Optional: override only the Eve assistant model/context window.
# Defaults to a smaller assistant model; AI_MODEL is still used for recipe analysis.
# EVE_MODEL=openai/gpt-4o-mini
# EVE_MODEL_CONTEXT_WINDOW_TOKENS=128000

# --- Neon Postgres (auto-set by the Vercel Neon integration) ---
# For local dev, paste a Neon connection string here.
DATABASE_URL=
